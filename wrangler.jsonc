{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "samuelcosta-me",
  "compatibility_date": "2026-04-04",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}