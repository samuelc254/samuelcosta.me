---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NewBadge from '../../components/NewBadge.astro';

export async function getStaticPaths() {
  const posts: CollectionEntry<'posts'>[] = await getCollection('posts');
  return posts.map((post: CollectionEntry<'posts'>) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/i, '') },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const { Content } = await render(post);
const formattedDate = post.data.pubDate.toISOString().split('T')[0].replace(/-/g, '/');

const accentText = {
  mint: 'text-p-mint-light dark:text-p-mint-dark',
  amber: 'text-p-amber-light dark:text-p-amber-dark',
  blue: 'text-p-blue-light dark:text-p-blue-dark',
  peach: 'text-p-peach-light dark:text-p-peach-dark',
}[post.data.accentColor as 'mint' | 'amber' | 'blue' | 'peach'] || 'text-p-mint-light dark:text-p-mint-dark';
---

<Layout title={`${post.data.title} // Samuel O. Costa`} description={post.data.description}>
  <main class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <article id="post-body">
      <header class="mb-12 border-b border-app-border-light dark:border-app-border-dark pb-10">
        <div class="flex items-center gap-2 flex-wrap mb-8">
          <time class={`font-mono text-[10px] uppercase tracking-[0.3em] bg-slate-100 dark:bg-slate-900 px-3 py-1.5 rounded-md border-1 border-slate-200 dark:border-slate-800 ${accentText} font-bold`}>
            {formattedDate}
          </time>
          <NewBadge pubDate={post.data.pubDate} class="px-3 py-1.5" />
        </div>
        
        <h1 class={`text-4xl md:text-5xl lg:text-6xl font-bold mb-8 leading-[1.1] tracking-tight text-slate-900 dark:text-slate-50`}>
          {post.data.title}
        </h1>
        
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-[10px] font-mono text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-900/50 px-2 py-1 rounded border-1 border-slate-300/70 dark:border-slate-800/50">{tag}</span>
          ))}
        </div>
      </header>
      
      <div class="prose prose-slate lg:prose-lg dark:prose-invert prose-headings:font-mono prose-headings:tracking-tight prose-a:text-p-blue-light dark:prose-a:text-p-blue-dark hover:prose-a:text-p-mint-light dark:hover:prose-a:text-p-mint-dark prose-a:transition-colors prose-pre:bg-slate-900 dark:prose-pre:bg-app-card-dark prose-pre:border prose-pre:border-slate-800 prose-img:rounded-2xl max-w-none prose-code:text-p-amber-light dark:prose-code:text-p-amber-dark">
        <Content />
      </div>
    </article>

    <footer class="mt-20 pt-10 border-t border-app-border-light dark:border-app-border-dark flex justify-between items-center">
      <a href="/" class="inline-flex items-center gap-3 font-mono text-xs text-slate-500 hover:text-slate-900 dark:hover:text-white transition-all group font-bold tracking-widest">
        <span class="group-hover:-translate-x-1 transition-transform">&lt;--</span> 
        RETURN_TO_SYSTEM
      </a>
    </footer>
  </main>
</Layout>
