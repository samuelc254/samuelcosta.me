<button 
  id="theme-toggle" 
  class="fixed top-6 right-6 z-50 w-12 h-12 rounded-xl bg-app-card-light dark:bg-app-card-dark border-1 border-app-border-light dark:border-app-border-dark flex items-center justify-center text-slate-600 dark:text-slate-400 hover:border-p-mint-light dark:hover:border-p-mint-dark hover:text-p-mint-light dark:hover:text-p-mint-dark shadow-xl backdrop-blur-md transition-colors duration-300 group"
  aria-label="Toggle Theme"
>
  <span class="relative block w-5 h-5 overflow-hidden isolate pointer-events-none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 w-5 h-5 transform-gpu will-change-transform transition-[opacity,transform] duration-300 ease-out opacity-100 rotate-0 scale-100 dark:opacity-0 dark:rotate-45 dark:scale-75" aria-hidden="true">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="M4.93 4.93l1.41 1.41"></path>
      <path d="M17.66 17.66l1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="M6.34 17.66l-1.41 1.41"></path>
      <path d="M19.07 4.93l-1.41 1.41"></path>
    </svg>
    <svg viewBox="0 0 24 24" fill="currentColor" class="absolute inset-0 w-5 h-5 transform-gpu will-change-transform transition-[opacity,transform] duration-300 ease-out opacity-0 -rotate-45 scale-75 dark:opacity-100 dark:rotate-0 dark:scale-100" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79Z"></path>
    </svg>
  </span>
</button>

<script is:inline>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById("theme-toggle");
    if (toggle) {
        toggle.removeEventListener("click", handleToggleClick);
        toggle.addEventListener("click", handleToggleClick);
    }
  });
</script>
