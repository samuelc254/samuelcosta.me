---
interface Props {
	pubDate: Date;
	class?: string;
}

const { pubDate, class: className = '' } = Astro.props;
---

<span
	class={`font-mono text-[10px] uppercase tracking-[0.3em] bg-blue-500/10 dark:bg-blue-400/10 px-2 py-1 rounded-md border-1 border-blue-500/20 dark:border-blue-400/20 text-blue-600 dark:text-blue-300 font-bold ${className}`}
	data-post-new-badge
	data-pub-date={pubDate.toISOString()}
	data-new-window-days="7"
	hidden
	aria-hidden="true"
>
	new
</span>