---
import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	type?: 'website' | 'article';
	image?: string;
	noindex?: boolean;
	keywords?: string[];
	publishedTime?: string;
	modifiedTime?: string;
	jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title,
	description = 'Samuel O. Costa // Software Engineer | Firmware, Embedded & Simulation',
	type = 'website',
	image = '/og-image.svg',
	noindex = false,
	keywords = [],
	publishedTime,
	modifiedTime,
	jsonLd,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://samuelcosta.me');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const robotsContent = noindex ? 'noindex, nofollow, noarchive' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';

const baseJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Samuel O. Costa',
		url: siteUrl.toString(),
		description,
		inLanguage: 'pt-BR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Samuel O. Costa',
		url: siteUrl.toString(),
		sameAs: [
			'https://github.com/samuelocosta',
			'https://www.linkedin.com/in/samuel-oliveira-costa-25388481/',
			'https://www.youtube.com/@samuelocosta',
		],
		knowsAbout: ['Embedded Systems', 'Python', 'C#', 'Linux', 'Hardware', 'Simulation'],
	},
];

const pageJsonLd = jsonLd
	? Array.isArray(jsonLd)
		? jsonLd
		: [jsonLd]
	: [];

const allJsonLd = [...baseJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="pt-BR" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link id="site-favicon" rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="canonical" href={canonicalUrl} />
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		<meta name="author" content="Samuel O. Costa" />
		<meta name="publisher" content="Samuel O. Costa" />
		<meta name="format-detection" content="telephone=no" />
		{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

		<meta property="og:site_name" content="Samuel O. Costa" />
		<meta property="og:locale" content="pt_BR" />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:alt" content={title} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<meta name="twitter:creator" content="@samuelocosta" />

		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

		<script is:inline type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />
		
		<script is:inline>
			const FAVICON_DARK = '/favicon.svg?v=2';
			const FAVICON_LIGHT = '/favicon-light.svg?v=1';

			const applyFavicon = (isDark) => {
				const favicon = document.getElementById('site-favicon');
				if (favicon) {
					favicon.setAttribute('href', isDark ? FAVICON_DARK : FAVICON_LIGHT);
				}
			};

			const syncNewPostBadges = () => {
				const now = Date.now();
				const badges = document.querySelectorAll('[data-post-new-badge]');

				badges.forEach((badge) => {
					const publishedAt = Date.parse(badge.getAttribute('data-pub-date') || '');
					const windowDays = Number(badge.getAttribute('data-new-window-days') || '7');
					const isNew = Number.isFinite(publishedAt) && now - publishedAt < windowDays * 24 * 60 * 60 * 1000;

					badge.hidden = !isNew;
					badge.setAttribute('aria-hidden', String(!isNew));
				});
			};

			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();

			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}

			applyFavicon(theme === 'dark');
			syncNewPostBadges();

			const faviconObserver = new MutationObserver(() => {
				applyFavicon(document.documentElement.classList.contains('dark'));
			});

			faviconObserver.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ['class'],
			});

			document.addEventListener('astro:page-load', () => {
				applyFavicon(document.documentElement.classList.contains('dark'));
				syncNewPostBadges();
			});
		</script>

		<ClientRouter />

		<script is:inline>
			document.addEventListener('astro:before-swap', (ev) => {
				const isDark = document.documentElement.classList.contains('dark');

				if (isDark) {
					ev.newDocument.documentElement.classList.add('dark');
				} else {
					ev.newDocument.documentElement.classList.remove('dark');
				}

				const nextHref = isDark ? '/favicon.svg?v=2' : '/favicon-light.svg?v=1';
				const newDocFavicon = ev.newDocument.getElementById('site-favicon');
				if (newDocFavicon) {
					newDocFavicon.setAttribute('href', nextHref);
				}
			});
		</script>

		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@300;400;500;600;700&display=swap');
			
			:root {
				--bg-pattern: rgba(30, 41, 59, 0.1);
			}
			.dark {
				--bg-pattern: rgba(30, 41, 59, 0.4);
			}

			body {
				background-image: radial-gradient(circle at center, var(--bg-pattern) 1px, transparent 1px);
				background-size: 24px 24px;
				scrollbar-width: thin;
			}
			
			/* Custom scrollbar based on theme */
			::-webkit-scrollbar { width: 8px; }
			::-webkit-scrollbar-track { @apply bg-app-bg-light dark:bg-app-bg-dark; }
			::-webkit-scrollbar-thumb { @apply bg-slate-300 dark:bg-slate-800 rounded-full; }
			
			/* Typography contrast fixes */
			.prose { @apply text-slate-700 dark:text-slate-300; }
			.prose h1, .prose h2, .prose h3 { @apply text-slate-900 dark:text-slate-50; }
		</style>
	</head>
	<body class="font-sans min-h-screen bg-app-bg-light dark:bg-app-bg-dark text-slate-900 dark:text-slate-100">
		
		<ThemeToggle />

		<!-- Top subtle glow - adjusted for theme -->
		<div class="fixed top-0 inset-x-0 h-64 bg-gradient-to-b from-blue-500/5 dark:from-p-blue-dark/10 to-transparent pointer-events-none z-0"></div>

		<slot />
	</body>
</html>
